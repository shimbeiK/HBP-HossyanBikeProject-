<mujoco model="HBP_mjcf">
  <!-- <compiler angle="radian" meshdir="assets" autolimits="true" /> -->
  <compiler angle="radian" autolimits="true" />

  <option timestep="0.002" iterations="30" cone="elliptic" impratio="100" />

  <default>
    <!-- textset -->
    <!-- <joint damping="0.001" armature="0.0001" frictionloss="0.0005"/> -->
    <position inheritrange="1" timeconst="0.01"/>
    <geom friction="0.4" margin="0.001" condim="3"/>
    <!-- text�[text�Fgroup=0 -->
    <default class="collision">
      <geom group="0"/>
    </default>
    <!-- text�Fgroup=1(text) -->
    <default class="visual">
      <geom contype="0" conaffinity="0" group="1"/>
    </default>
  </default>

  <asset>
    <material name="metal" rgba=".9 .95 .95 1" />
    <material name="black" rgba="0 0 0 1" />
    <material name="white" rgba="1 1 1 1" />
    <material name="gray" rgba="0.671705 0.692426 0.774270 1" />
    <mesh name="body" file="assets/body.obj" />
    <mesh name="back_tire" file="assets/tire_back.obj" />
    <mesh name="front_tire_holder" file="assets/tire_holder.obj" />
    <mesh name="front_tire" file="assets/tire_top.obj" />
  </asset>

<worldbody>
    <body name="body_obj" pos="0 0 0.036">
      <freejoint />
      <!-- <joint type="slide" axis="1 0 0" pos="0 0 0" name="root_x"/>
      <joint type="slide" axis="0 1 0" pos="0 0 0" name="root_y"/>
      <joint type="slide" axis="0 0 1" pos="0 0 0" name="root_z"/>
      <joint type="hinge" axis="0 1 0" pos="0 0 0" name="root_y_arg"/>
      <joint type="hinge" axis="0 0 1" pos="0 0 0" name="root_z_arg"/>
      <joint type="hinge" axis="1 0 0" pos="0 0 0" name="root_x_arg"/> -->
      <site name="imu_site" pos="-0.05 0 0.07" size="0.005"/>
      <geom class="visual" type="mesh" mesh="body" rgba="1.0 1.0 1.0 1.0" />
      <geom type="mesh" mesh="body" group="0"/>
      <inertial pos="-0.050997 -0.017947 0.030732" mass="0.245161" diaginertia="2.267e-4 6.820e-4 5.311e-4" />

      <!-- back_tire -->
      <body name="back_tire" pos="0.0 -0.0205 -0.0075">
        <!-- <joint name="back_tire_pitch" type="hinge" pos="0 0 0" axis="0 1 0" limited="false" armature="0.00001" frictionloss="0.0005" damping="0.00001" /> -->
        <joint name="back_tire_pitch" type="hinge" pos="0 0 0" axis="0 1 0" limited="false" damping="0.00001" />
        <inertial pos="0 0.002773 0" mass="0.0175" diaginertia="5.657063e-6 1.0383774e-5 5.657062e-6" />
        <!-- <geom class="visual" type="mesh" mesh="back_tire" /> -->
        <!-- <geom type="cylinder" size="0.031 0.0045" material="wheel_material" euler="1.570796327 0 0"
                            solref="0.02 1" solimp="0.9 0.95 0.001" friction="1.6 0.005 0.0002"
                            contype="1" conaffinity="1" /> -->
        <geom type="mesh" mesh="back_tire" group="0" friction="1.6 0.005 0.00002"/> 
        <geom type="box" size="0.005 0.005 0.002" pos="0.02 -0.002 0" rgba="1 0 0 1"/>
      </body>

      <!-- tire_holder -->
      <body name="front_tire_holder" pos="-0.105 -0.0205 0.0365">
        <joint name="tire_holder_yaw" type="hinge" pos="0 0 0" axis="0 0 1" range="-3.14159 3.14159" limited="false" margin="0.0035" armature="0.0005" frictionloss="0.0005" damping="0.00001" />
        <!-- <joint name="tire_holder_yaw" type="hinge" pos="0 0 0" axis="0 0 1" range="-3.14159 3.14159" limited="false" margin="0.0035" damping="0.00001" /> -->
        <inertial pos="-0 -0 -0.01725" mass="0.008584" diaginertia="2.66356e-6 2.280561e-6 1.309661e-6" />
        <geom class="visual" type="mesh" mesh="front_tire_holder" rgba="1.0 1.0 1.0 1.0" contype="0" conaffinity="0"/>
        <geom type="mesh" mesh="front_tire_holder" group="0" />

        <!-- front_tire キャスター化-->
        <body name="front_tire" pos="0.0 -0.00 -0.04">
          <!-- <joint name="front_tire_pitch" type="hinge" pos="0 0 0" axis="0 1 0" limited="false" armature="0.00001" frictionloss="0.0005" damping="0.00001" /> -->
          <joint name="front_tire_pitch" type="hinge" pos="0 0 0" axis="0 1 0" limited="false" damping="0.00001" />
          <inertial pos="0 0.005508 0" mass="0.0185" diaginertia="6.513973e-6 1.2471945e-5 6.513973e-6" />
          <!-- <geom class="visual" type="mesh" mesh="front_tire" rgba="1.0 1.0 1.0 1.0" /> -->
          <geom type="mesh" mesh="front_tire" group="0" friction="1.6 0.05 0.00002"/>
          <!-- <geom type="cylinder" size="0.031 0.005" euler="1.570796327 0 0" material="wheel_material"
                            solref="0.02 1" solimp="0.9 0.95 0.001" friction="1.6 0.005 0.0002" 
                            contype="1" conaffinity="1" group="1"/> -->
          <geom type="box" size="0.005 0.005 0.002" pos="0.02 -0.002 0" rgba="1 0 0 1"/>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <position name="fork_controler" joint="tire_holder_yaw" gear="1" kp="100" kv="1" forcerange="-1.37 1.37" forcelimited="true"/>
      <general name="back_tire_motor" joint="back_tire_pitch" 
              ctrlrange="-0.0233 0.0233" ctrllimited="true"
              dyntype="filter" dynprm="0.0055"
              gaintype="fixed" gainprm="1"
              biastype="affine" biasprm="0 -0.000333 0"/> 
              
      <general name="front_tire_motor" joint="front_tire_pitch" 
              ctrlrange="-0.0233 0.0233" ctrllimited="true"
              dyntype="filter" dynprm="0.0055"
              gaintype="fixed" gainprm="1"
              biastype="affine" biasprm="0 -0.000333 0"/>
              
  </actuator>

  <contact>
    <exclude body1="body_obj" body2="back_tire" />
    <exclude body1="body_obj" body2="front_tire" />
    <exclude body1="body_obj" body2="front_tire_holder" />
    <exclude body1="front_tire_holder" body2="front_tire" />
  </contact>

  <sensor>
    <accelerometer name="body_accel" site="imu_site"/>
    <gyro name="body_gyro" site="imu_site" />  
  </sensor>
</mujoco>
